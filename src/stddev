#!/usr/bin/env python3
import sys
import os
from math_lib import MathLib

# Initialize accumulators for statistical calculations
n = 0               # Sample size
sum_x = 0.0         # Sum of all input values
sum_x_sq = 0.0      # Sum of squares of input values

def process_value(val_str):
    """
    @brief Processes a biological string input, converts it to a float, and updates global statistical accumulators.
    @param val_str The input string representing a numerical value.
    @return None
    """
    global n, sum_x, sum_x_sq
    try:
        val = float(val_str)
        n += 1
        sum_x = MathLib.add(sum_x, val)
        sum_x_sq = MathLib.add(MathLib.pow(val, 2), sum_x_sq)
    except ValueError:
        pass

# Handle input arguments or standard input 
if len(sys.argv) > 1:
    
    for arg in sys.argv[1:]:
        process_value(arg)
else:
    # Check if standard input is available
    if sys.stdin.isatty():
        sys.stderr.write("Error: No input provided.\n")
        sys.exit(1)

    # Process values from standard input
    for line in sys.stdin:
        for word in line.split():
            process_value(word)

def calculate_mean(n, sum_x):
    """
    @brief Calculates the arithmetic mean from the number of elements and their sum.
    @param n The sample size .
    @param sum_x The total sum of the values.
    @return The arithmetic mean as a float, or 0.0 if the sample size is insufficient.
    """

    if n < 2:
        return 0.0
    if n == 0:
        return 0
    
    mean =MathLib.div(sum_x,n)
    return mean



def calculate_stddev(n, sum_x, sum_x_sq):
    """
    @brief Calculates the sample standard deviation.
    @param n The sample size.
    @param sum_x The total sum of the values.
    @param sum_x_sq The total sum of the squares of the values.
    @return The sample standard deviation as a float.
    """

    numerator = MathLib.sub(sum_x_sq, MathLib.mul(n, MathLib.pow(calculate_mean(n, sum_x), 2)))

    # Prevent potential negative values due to floating-point errors
    if numerator < 0:
        numerator = 0.0

    temp = MathLib.div(numerator, MathLib.sub(n, 1))

    return MathLib.root(temp,2)



# Standard deviation requires at least two points
if n >1:
    result = calculate_stddev(n, sum_x, sum_x_sq)
    print(result)

# Standard deviation of a single value is defined as 0.0
elif n==1 :
    print("0.0")


# No data to process
else:
    sys.exit(0)